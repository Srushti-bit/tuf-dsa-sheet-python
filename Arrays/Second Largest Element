nums = [8, 8, 7, 6, 5]

class Solution:
    def secondLargest(self, nums):
        largest = self.secondLargest = -1

        for num in nums:
            if num > largest:
                secondLargest = largest
                largest = num

            elif num > secondLargest and num != largest:
                secondLargest = num   

        return secondLargest         
             
obj = Solution()
print(obj.secondLargest(nums))             
